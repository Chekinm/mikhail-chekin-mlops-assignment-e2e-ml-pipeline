# --- Inference credentials ---
# Nebius Token Factory API key (used by mini-swe-agent via litellm)
NEBIUS_API_KEY=

# HuggingFace token for dataset downloads (higher rate limits)
HF_TOKEN=

# --- Host-specific settings (change per machine) ---
# Absolute path to this project on the host
# (needed by DockerOperator to mount host paths into sibling containers)
HOST_PROJECT_DIR=/home/mikhail/mikhail-chekin-mlops-assignment-e2e-ml-pipeline

# HuggingFace cache on the host (shared with agent/eval containers)
HOST_HF_CACHE_DIR=/home/mikhail/.cache/huggingface

# Your user ID on the host: id -u
AIRFLOW_UID=1001

# GID of the 'docker' group on the host: getent group docker | cut -d: -f3
DOCKER_GID=987

# --- Object storage (MinIO) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_BUCKET=mlops-runs